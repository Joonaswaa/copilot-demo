# ---------------------------------------------------------------
# Telecom Supply Chain AI Copilot - environment configuration
# Copy this file to .env and fill in the values you need.
# The app runs fully WITHOUT any of these (rule-based fallbacks).
# ---------------------------------------------------------------

# --- LLM report generation (optional, pick one) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
#
# Provider override (optional): anthropic | openai
# If omitted, Anthropic is preferred when both keys are set.
# LLM_PROVIDER=anthropic
#
# Model overrides (optional):
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=2500

# --- Email sending (optional) ---
# Required for "Send by email" on the AI weekly report page.
#
# Gmail example (use an App Password, not your login password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USE_SSL=false
#
# Outlook / Microsoft 365 example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#
# SSL-only provider (port 465):
#   SMTP_PORT=465
#   SMTP_USE_SSL=true
#   SMTP_USE_TLS=false

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=reports@example.com
# SMTP_PASSWORD=change-me
# REPORT_SENDER=reports@example.com
# REPORT_RECIPIENTS=manager@example.com,logistics@example.com
